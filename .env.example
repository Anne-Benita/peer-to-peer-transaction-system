# Server Configuration
PORT=8080
ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=p2p_admin
DB_PASSWORD=p2p_secure_pass
DB_NAME=p2p_wallet
DB_SSLMODE=disable

# JWT Authentication
JWT_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production

# Wallet & Financial Settings
MIN_TRANSFER_AMOUNT=100.00
CURRENCY=XAF
